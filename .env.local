# Next.js Dev Server Optimizations

# Disable telemetry to speed up startup
NEXT_TELEMETRY_DISABLED=1

# Enable SWC minification for faster builds
NEXT_TRANSPILE_MODULES=@supabase/supabase-js

# File watching improvements
# This helps reduce CPU usage from file watching
NEXT_DEV_POLL_INTERVAL=

# TypeScript performance
NEXT_TYPESCRIPT_SWC=true
